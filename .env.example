# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────
# Railway auto-provides DATABASE_URL — just link the PostgreSQL service
# For local development, use individual vars below:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

DB_HOST=localhost
DB_PORT=5432
DB_NAME=optionlab
DB_USER=postgres
DB_PASSWORD=your_db_password

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=another_long_random_string

# ─── Fast2SMS ─────────────────────────────────────────
# Get from: https://www.fast2sms.com → Dashboard → Dev API
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ─── Admin Setup ──────────────────────────────────────
# Used once to create first admin account via POST /api/admin/setup
ADMIN_SECRET_KEY=create_a_strong_secret_key_here

# ─── CORS Origins ─────────────────────────────────────
# Add all domains that need API access
ALLOWED_ORIGINS=https://optionlab.in,https://optionlab.in/admin

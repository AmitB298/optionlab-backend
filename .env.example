# ── Database (Railway sets this automatically) ────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── JWT Secret (generate: openssl rand -hex 32) ───────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# ── Environment ───────────────────────────────────────────────────────────
NODE_ENV=production

# ── Razorpay (get from dashboard.razorpay.com) ────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Jobber Pro Download ───────────────────────────────────────────────────
# Option A: Set this to serve from external URL (S3, Google Drive, etc.)
DOWNLOAD_URL=https://your-s3-bucket.s3.ap-south-1.amazonaws.com/JobberPro-Setup-1.0.0.exe
# Option B: Leave blank and place .exe in public/releases/ folder

# App version info (shown in dashboard)
APP_VERSION=1.0.0
APP_FILENAME=JobberPro-Setup-1.0.0.exe
APP_RELEASE_DATE=2026-03-28
APP_CHANGELOG=Initial release — Live Options Chain, GEX, Strategy Lab, IV Rank

# ── Email (Resend / SMTP) ─────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@optionslab.in
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@optionslab.in

# ── Error Monitoring (sentry.io — free tier is fine) ─────────────────────
# 1. Go to sentry.io → New Project → Node.js
# 2. Copy the DSN and paste here
SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxxxx

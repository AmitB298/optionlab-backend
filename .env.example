# Railway sets DATABASE_URL automatically when Postgres is connected
DATABASE_URL=postgresql://user:password@host:5432/railway

# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-here

# Set to 'production' on Railway
NODE_ENV=production

# SMS API (optional)
FAST2SMS_API_KEY=your-key-here
